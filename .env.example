# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only, never NEXT_PUBLIC

# football-data.org (free tier: https://www.football-data.org/client/register)
FOOTBALL_DATA_TOKEN=your-token

# Random string; protects the /api/sync endpoint
SYNC_SECRET=change-me

# Your deployed URL (used for OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
